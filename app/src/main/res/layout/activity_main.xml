<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp">

        <!-- ── Header ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WebM → GIF"
            android:textColor="#F0EEFF"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="本地转换 · 基于 FFmpeg · 文件不离开手机"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:layout_marginBottom="32dp" />

        <!-- ── 选择文件 ── -->
        <Button
            android:id="@+id/btnPick"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="选择 WebM 文件"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8B5CF6"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#8B5CF6"
            android:textSize="13sp"
            android:ellipsize="middle"
            android:singleLine="true"
            android:layout_marginBottom="28dp" />

        <!-- ── 参数设置（文件选中后显示）── -->
        <LinearLayout
            android:id="@+id/layoutSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 分组卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- FPS -->
                <TextView style="@style/LabelText" android:text="帧率" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">
                    <SeekBar
                        android:id="@+id/seekFps"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progressTint="#8B5CF6"
                        android:thumbTint="#8B5CF6" />
                    <TextView
                        android:id="@+id/tvFps"
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:textColor="#8B5CF6"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>

                <!-- 宽度 -->
                <TextView style="@style/LabelText" android:text="输出宽度" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <SeekBar
                        android:id="@+id/seekWidth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:progressTint="#8B5CF6"
                        android:thumbTint="#8B5CF6" />
                    <TextView
                        android:id="@+id/tvWidth"
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:textColor="#8B5CF6"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- 质量 & 循环 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView style="@style/LabelText" android:text="色彩质量" />
                    <Spinner
                        android:id="@+id/spinnerQuality"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/spinner_bg" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView style="@style/LabelText" android:text="循环方式" />
                    <Spinner
                        android:id="@+id/spinnerRepeat"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/spinner_bg" />
                </LinearLayout>
            </LinearLayout>

            <!-- 转换按钮 -->
            <Button
                android:id="@+id/btnConvert"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="开始转换"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#8B5CF6"
                android:enabled="false"
                android:layout_marginBottom="16dp" />

            <!-- 进度 -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="#8B5CF6"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8888AA"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="12dp" />

            <!-- 错误日志 -->
            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F87171"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <!-- ── 结果 ── -->
            <LinearLayout
                android:id="@+id/layoutResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvResultInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#34D399"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnShare"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="分享 GIF"
                    android:textColor="#0D0D0F"
                    android:textSize="15sp"
                    android:backgroundTint="#34D399"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="保存到下载文件夹"
                    android:textColor="#F0EEFF"
                    android:textSize="15sp"
                    android:backgroundTint="#1E1E26" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
